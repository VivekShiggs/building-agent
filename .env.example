# Google Sheets (optional — only needed for Sheets sync)
# Create a service account: https://console.cloud.google.com/apis/credentials
# Then share your Google Sheet with the service account email.
GOOGLE_SHEETS_CREDENTIALS=service_account.json
GOOGLE_SHEET_ID=your_google_sheet_id_here

# Nominatim (optional — custom endpoint for reverse geocoding)
# Leave blank to use the public OSM Nominatim (rate-limited to 1 req/s).
NOMINATIM_URL=https://nominatim.openstreetmap.org

# Model directory (optional — override default path)
MODEL_DIR=data/models
